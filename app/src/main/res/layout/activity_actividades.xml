<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/Fondo_pantallas"
    android:layout_height="match_parent"
    tools:context=".caht.actividades">

        <LinearLayout
            android:id="@+id/container_header"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_gravity="center"
            android:background="@color/Fondo_del_header"
            >

            <ImageView
               android:layout_margin="10px"
                android:layout_width="80dp"
                android:layout_height="50dp"
                android:src="@drawable/tas_pro" />


            <ImageView
                android:id="@+id/flecha_atras"
                android:layout_width="60dp"
                android:layout_height="20dp"
               android:layout_marginTop="20dp"
                android:layout_marginLeft="-20dp"


                app:srcCompat="@mipmap/flecha" />

            <LinearLayout
                android:id="@+id/pefil"
                android:layout_width="170dp"
                android:layout_height="50dp"
                android:layout_marginLeft="100dp"
                android:layout_gravity="center">
                <TextView
                    android:layout_marginLeft=".20dp"
                    android:layout_marginTop="30px"
                    android:layout_width="120dp"
                    android:layout_height="26dp"
                    android:text="jhonatan mayorga"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:srcCompat="@mipmap/perfil" />
            </LinearLayout>

        </LinearLayout>


    <LinearLayout
        android:id="@+id/container_actividades"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:layout_gravity="center"
        android:background="@color/Fondo_pantallas"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="128dp">

        <LinearLayout
            android:layout_marginLeft="15dp"
            android:id="@+id/pefil"
            android:layout_width="185dp"
            android:layout_height="200dp"
            android:orientation="vertical"

            android:background="@drawable/borde_blanco">
            <ImageView
                android:layout_marginTop="30dp"
                android:id="@+id/imageView5"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                app:srcCompat="@mipmap/perfil" />
            <TextView
                android:layout_gravity="center"
                android:layout_width="120dp"
                android:layout_height="26dp"
                android:layout_marginLeft=".20dp"
                android:layout_marginTop="30px"
                android:text="jhonatan mayorga"
                android:textColor="@color/white"
                android:textSize="15sp" />


        </LinearLayout>
        <LinearLayout
            android:layout_marginLeft="15dp"
            android:id="@+id/pefil"
            android:layout_width="185dp"
            android:layout_height="200dp"
            android:orientation="vertical"

            android:background="@drawable/borde_blanco">
            <ImageView
                android:layout_marginTop="30dp"
                android:id="@+id/imageView5"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                app:srcCompat="@mipmap/perfil" />
            <TextView
                android:layout_gravity="center"
                android:layout_width="120dp"
                android:layout_height="26dp"
                android:layout_marginLeft=".20dp"
                android:layout_marginTop="30px"
                android:text="jhonatan mayorga"
                android:textColor="@color/white"
                android:textSize="15sp" />


        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/Fondo_del_header"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:menu="@menu/menu_drawer"
        tools:layout_editor_absoluteX="-16dp"
        tools:layout_editor_absoluteY="652dp" />

</androidx.constraintlayout.widget.ConstraintLayout>