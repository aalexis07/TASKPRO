<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITULO -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar Perfil"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"/>

        <!-- CARD PRINCIPAL -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#1E293B"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- FOTO -->

                <FrameLayout
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_marginBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        app:cardCornerRadius="65dp"
                        app:cardElevation="4dp">

                        <ImageView
                            android:id="@+id/iv_editar_foto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher_round"
                            android:contentDescription="@string/foto_de_perfil"/>

                    </androidx.cardview.widget.CardView>

                    <!-- BOTON CAMARA -->

                    <ImageView
                        android:id="@+id/iv_camara_icon"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_avatar"
                        android:padding="8dp"
                        android:elevation="10dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:tint="@android:color/white"
                        android:contentDescription="@string/cambiar_foto"/>

                </FrameLayout>

                <!-- NOMBRES -->

                <EditText
                    android:id="@+id/et_editar_nombres"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/style_edit_text"
                    android:hint="Nombres"
                    android:textColorHint="#94A3B8"
                    android:paddingStart="16dp"
                    android:textColor="@android:color/white"
                    android:inputType="textPersonName"/>

                <!-- APELLIDOS -->

                <EditText
                    android:id="@+id/et_editar_apellidos"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/style_edit_text"
                    android:hint="Apellidos"
                    android:textColorHint="#94A3B8"
                    android:paddingStart="16dp"
                    android:textColor="@android:color/white"
                    android:inputType="textPersonName"/>

                <!-- CORREO -->

                <EditText
                    android:id="@+id/et_editar_correo"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/style_edit_text"
                    android:hint="Correo"
                    android:textColorHint="#94A3B8"
                    android:paddingStart="16dp"
                    android:textColor="@android:color/white"
                    android:inputType="textEmailAddress"/>

                <!-- CONTRASEÑA -->

                <EditText
                    android:id="@+id/et_editar_contrasena"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/style_edit_text"
                    android:hint="Nueva contraseña"
                    android:textColorHint="#94A3B8"
                    android:paddingStart="16dp"
                    android:textColor="@android:color/white"
                    android:inputType="textPassword"/>

                <!-- REPETIR -->

                <EditText
                    android:id="@+id/et_editar_recontrasena"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/style_edit_text"
                    android:hint="Repetir contraseña"
                    android:textColorHint="#94A3B8"
                    android:paddingStart="16dp"
                    android:textColor="@android:color/white"
                    android:inputType="textPassword"/>

                <!-- BOTON -->

                <Button
                    android:id="@+id/btn_guardar_perfil"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Guardar Cambios"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:backgroundTint="#2563EB"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>