<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="#1E293B"
    app:strokeColor="#334155"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tv_nombre_empleado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Empleado"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/tv_correo_empleado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="correo@taskpro.com"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

        <Button
            android:id="@+id/btn_asignar_tarea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asignar tarea"
            android:layout_marginTop="12dp"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>