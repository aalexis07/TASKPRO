<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITULO -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi Perfil"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginBottom="24dp"/>

        <!-- CARD PERFIL -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#1E293B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <!-- FOTO -->

                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:id="@+id/iv_foto_perfil"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher_round"
                        android:contentDescription="@string/foto_de_perfil"/>

                </androidx.cardview.widget.CardView>

                <!-- NOMBRE -->

                <TextView
                    android:id="@+id/tv_perfil_nombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuario"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:layout_marginTop="16dp"/>

                <!-- ROL -->

                <TextView
                    android:id="@+id/tv_perfil_rol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Administrador"
                    android:textColor="#38BDF8"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <!-- CORREO -->

                <TextView
                    android:id="@+id/tv_perfil_correo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="correo@correo.com"
                    android:textColor="#CBD5E1"
                    android:textSize="15sp"
                    android:layout_marginTop="12dp"/>

                <!-- BOTON -->

                <Button
                    android:id="@+id/btn_editar_perfil"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Editar Perfil"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#2563EB"
                    android:layout_marginTop="24dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>